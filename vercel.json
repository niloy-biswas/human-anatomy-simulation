{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/",         "destination": "/body" },
    { "source": "/skeletal", "destination": "/body" },
    { "source": "/joints",   "destination": "/body" },
    { "source": "/muscular", "destination": "/body" },
    { "source": "/fasciae",  "destination": "/body" },
    { "source": "/arterial", "destination": "/body" },
    { "source": "/venous",   "destination": "/body" },
    { "source": "/lymphoid", "destination": "/body" },
    { "source": "/nervous",  "destination": "/body" },
    { "source": "/visceral", "destination": "/body" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)\\.glb",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
